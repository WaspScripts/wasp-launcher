{
	"identifier": "desktop-capability",
	"platforms": ["macOS", "windows", "linux"],
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"store:default",
		"fs:default",
		"http:default",
		"dialog:default",
		{
			"identifier": "http:default",
			"allow": [
				{
					"url": "http://localhost:*"
				},
				{
					"url": "https://api.waspscripts.dev"
				},
				{
					"url": "https://db.waspscripts.dev"
				}
			]
		}
	]
}
